<h1>Articles#index</h1>
<h1>Hello, Rails!</h1>

<ul>
  <% @articles.each do |article| %>
    <% unless article.archived? %>
      <li>
        <%= link_to article.title, article %>
      </li>
    <% end %>
  <% end %>
</ul>

<p>Find me in app/views/articles/index.html.erb</p>
<%= link_to "New Article", new_article_path %>